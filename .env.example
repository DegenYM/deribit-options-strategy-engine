# =============================================================================
# Deribit Options Strategy Engine
# =============================================================================
# 使用方式（擇一）：
#   A) 建議：一位投資人 → 多子帳（各策略）
#      cp -R config/investors/_example config/investors/<your_id>
#      依 accounts/.env.<slug>.example 複製為 .env.<slug>
#      詳見 README「Investor / Sub-account Layout」
#   B) 本機試跑：cp .env.example .env（單帳、非 youming 子帳結構時）
#   策略 tuning：config/shared/strategies/.env.<strategy>
#   實單前先用 dry-run 確認 scan / enter-best / manage 行為
#
# 常用策略：
#   naked_short      - 單腿賣 put / call / both，尾端風險最高，依 SHORT_OPTION_SIDE 選邊。
#   bull_put_spread  - 賣 put 並買較低 strike put 作保護。
#   covered_call     - 只用既有 BTC/ETH 庫存賣 call，不自動買現貨。
#
# 參數數值多為比例：0.15 = 15%，0.08 delta = 8 delta。

# --- 1) 環境與憑證 ------------------------------------------------------------
# DERIBIT_ENV: mainnet only（prod 也會被視為 mainnet）。
DERIBIT_ENV=mainnet
DERIBIT_CLIENT_ID=
DERIBIT_CLIENT_SECRET=

# OPTION_STRATEGY: naked_short / bull_put_spread / covered_call
# 舊名 naked_short_put / naked_short_call 仍會被解析為 naked_short。
OPTION_STRATEGY=naked_short

# OPTION_MARKETS_PROFILE:
#   all            = 反向 BTC/ETH options + 線性 USDC options
#   inverse_native = 只掃 BTC/ETH 本位反向 options
#   linear_usdc    = 只掃 USDC 線性 options
OPTION_MARKETS_PROFILE=all

# SHORT_OPTION_SIDE: put / call / both。
# 在 naked_short 策略下，``both`` 會把 put 與 call 候選一起以同一組排序鍵
# (APR band → preferred delta/OTM → margin efficiency → spread → ...) 排序，
# 不會幫 call 預留名額。
SHORT_OPTION_SIDE=put

# --- 2) 投組範圍 --------------------------------------------------------------
# MANAGED_CURRENCIES 是策略管理的標的幣別，目前支援 BTC,ETH。
MANAGED_CURRENCIES=BTC,ETH

# TRADED_COLLATERALS 是實際建 book 並納入風控的抵押資產池。
# 只做 USDC 線性 options 時可改成 USDC；covered_call 通常用 BTC,ETH。
TRADED_COLLATERALS=BTC,ETH,USDC

# 帳本日初 equity 低於此 USDC 等值時，不納入 drawdown / IM gate。
# 可避免 BTC/ETH dust 造成假 drawdown；設 0 可停用。
MIN_BOOK_EQUITY_USDC=50

# 定期重新讀 transaction_log，將手動入金 / 出金 / 轉帳排除在策略損益之外。
CASH_FLOW_QUERY_INTERVAL_SECONDS=300

# 掃描時顯示前 N 個候選；REFERENCE_CAPITAL_USDC 用於投組 APR 目標換算。
TOP_N=5
REFERENCE_CAPITAL_USDC=1000
TARGET_PORTFOLIO_APR=0.25

# --- 3) 共用 fallback：DTE / Delta / OTM -------------------------------------
# 策略專屬推薦值請放在 config/shared/strategies/.env.<strategy>。
# 若 profile 不存在，才會使用下方 fallback。
PUT_DTE_MIN=10
PUT_DTE_MAX=21

# Put fallback；BTC/ETH 可用下方 per-underlying 參數覆蓋。
SHORT_PUT_DELTA_MIN=0.07
SHORT_PUT_DELTA_MAX=0.14
PREFERRED_SHORT_PUT_DELTA_MIN=0.08
PREFERRED_SHORT_PUT_DELTA_MAX=0.12
PUT_OTM_MIN=0.08
PUT_OTM_MAX=0.22

# BTC / ETH 的主要調參區。若不需要幣別差異，可刪除這段並使用內建預設。
BTC_PUT_DELTA_MIN=0.08
BTC_PUT_DELTA_MAX=0.14
BTC_PUT_OTM_MIN=0.08
BTC_PUT_OTM_MAX=0.20
BTC_PREFERRED_PUT_DELTA_MIN=0.09
BTC_PREFERRED_PUT_DELTA_MAX=0.12
BTC_PREFERRED_OTM_MIN=0.12
BTC_PREFERRED_OTM_MAX=0.16

ETH_PUT_DELTA_MIN=0.07
ETH_PUT_DELTA_MAX=0.12
ETH_PUT_OTM_MIN=0.10
ETH_PUT_OTM_MAX=0.22
ETH_PREFERRED_PUT_DELTA_MIN=0.08
ETH_PREFERRED_PUT_DELTA_MAX=0.10
ETH_PREFERRED_OTM_MIN=0.14
ETH_PREFERRED_OTM_MAX=0.18

# bull_put_spread 才會使用：long put 保護腿的 delta 範圍。
# 建議放在 .env.bull_put_spread；這裡保留未拆 profile 時的 fallback。
# BULL_PUT_LONG_DELTA_MIN=0.02
# BULL_PUT_LONG_DELTA_MAX=0.05

# covered_call 或 SHORT_OPTION_SIDE=call/both 才需要 call 參數。
# 建議放在 .env.covered_call；這裡保留未拆 profile 時的 fallback。
# SHORT_CALL_DELTA_MIN=0.18
# SHORT_CALL_DELTA_MAX=0.38
# PREFERRED_SHORT_CALL_DELTA_MIN=0.22
# PREFERRED_SHORT_CALL_DELTA_MAX=0.32
# CALL_OTM_MIN=0.025
# CALL_OTM_MAX=0.18
# BTC_CALL_DELTA_MIN=0.18
# BTC_CALL_DELTA_MAX=0.38
# BTC_CALL_OTM_MIN=0.025
# BTC_CALL_OTM_MAX=0.16
# BTC_PREFERRED_CALL_DELTA_MIN=0.22
# BTC_PREFERRED_CALL_DELTA_MAX=0.32
# BTC_PREFERRED_CALL_OTM_MIN=0.04
# BTC_PREFERRED_CALL_OTM_MAX=0.10
# ETH_CALL_DELTA_MIN=0.16
# ETH_CALL_DELTA_MAX=0.34
# ETH_CALL_OTM_MIN=0.035
# ETH_CALL_OTM_MAX=0.20
# ETH_PREFERRED_CALL_DELTA_MIN=0.20
# ETH_PREFERRED_CALL_DELTA_MAX=0.30
# ETH_PREFERRED_CALL_OTM_MIN=0.05
# ETH_PREFERRED_CALL_OTM_MAX=0.12

# --- 4) 流動性與 APR 門檻 -----------------------------------------------------
# Inverse books: BTC/ETH 本位反向 options；Linear book: USDC 線性 options。
# 流動性門檻通常共用；APR 可在策略 profile 覆蓋。
INVERSE_MIN_OPEN_INTEREST=20
# Optional per-underlying overrides. BTC_MIN_OPEN_INTEREST / ETH_MIN_OPEN_INTEREST
# apply to both inverse and linear unless the type-specific key is set.
# BTC_MIN_OPEN_INTEREST=20
# ETH_MIN_OPEN_INTEREST=12
# BTC_INVERSE_MIN_OPEN_INTEREST=20
# ETH_INVERSE_MIN_OPEN_INTEREST=12
INVERSE_MAX_SPREAD_RATIO=0.12
INVERSE_MIN_BOOK_NOTIONAL_USDC=3000
LINEAR_MIN_OPEN_INTEREST=8
# BTC_LINEAR_MIN_OPEN_INTEREST=8
# ETH_LINEAR_MIN_OPEN_INTEREST=5
LINEAR_MAX_SPREAD_RATIO=0.14
LINEAR_MIN_BOOK_NOTIONAL_USDC=4000
MIN_LIQUID_EXPIRIES_REQUIRED=2

# APR = annualized net entry credit / that collateral book's equity.
# Strategy profiles override this: covered_call > naked_short > bull_put_spread.
MIN_NET_APR=0.08
TARGET_NET_APR_MIN=0.10
TARGET_NET_APR_MAX=0.18

# --- 5) 帳本槓桿與風控上限 ----------------------------------------------------
# 每條腿最多使用該 book equity 的多少 IM；三條 put 腿約會打到 0.45 hard cap。
PER_LEG_IM_CAP_PUT=0.15
PER_LEG_IM_CAP_CALL=0.12
EXPIRY_IM_CAP=0.30
BOOK_IM_TARGET=0.35
BOOK_IM_HARD=0.45
BOOK_MM_TARGET=0.22
BOOK_MM_HARD=0.33

# 如需比 BOOK_IM_HARD 更早停止新倉，可取消註解（預設省略 = 跟 BOOK_IM_HARD）。
# OPEN_MAX_LOSS_HALT_RATIO=0.40

# --- 6) 持倉管理與退場 --------------------------------------------------------
TP_CAPTURE_PCT=0.55
ENABLE_EARLY_EXIT=true
EARLY_EXIT_REMAINING_APR=0.08
EARLY_EXIT_MIN_PROFIT_CAPTURE=0.45
EARLY_EXIT_MAX_SPREAD_RATIO=0.06
TIME_EXIT_DTE=4

# put 防守門檻；call-only / covered_call 可另外設定 *_CALL。
SOFT_DEFENSE_DELTA=0.20
HARD_DEFENSE_DELTA=0.28
# SOFT_DEFENSE_DELTA_CALL=0.18
# HARD_DEFENSE_DELTA_CALL=0.24
SOFT_DEFENSE_LOSS_PCT=0.30
HARD_STOP_LOSS_PCT=0.45

# covered_call 專用：ITM 時是否同步賣 Deribit spot。預設關閉，避免改變
# 既有只管理 option 的行為；即使啟用，也只有 --live 才會真的下 spot 單。
COVERED_CALL_SPOT_EXIT_ENABLED=false
# Robust mode 會在接近到期且 call 已 ITM 時先買回 short call，再賣
# BTC_USDT / ETH_USDT spot。關閉 robust 時，僅在結算後標記 pending，
# 下一次 manage 才會賣剩餘 spot。
COVERED_CALL_ROBUST_EXIT_ENABLED=false
COVERED_CALL_ROBUST_EXIT_DTE=0.5
COVERED_CALL_ITM_BUFFER_PCT=0
COVERED_CALL_SPOT_ORDER_TYPE=market
# Max slippage vs mark for covered-call spot sells (0 = no cap). 0.005 = 0.5% below mark.
COVERED_CALL_SPOT_MAX_SLIPPAGE_PCT=0.005
# Slot sizing (default true): each entry ≈ remaining cover / remaining MAX_GROUPS_PER_CURRENCY slots.
# COVERED_CALL_SLOT_SIZING=true

# --- 7) Regime / circuit breakers -------------------------------------------
INDEX_DRAWDOWN_ELEVATED_PCT=0.035
INDEX_DRAWDOWN_CRISIS_PCT=0.055
DVOL_ELEVATED_MULTIPLIER=1.20
DVOL_CRISIS_MULTIPLIER=1.50
HALT_DRAWDOWN_PCT=0.025
HARD_DERISK_DRAWDOWN_PCT=0.06
HARD_DERISK_MAINTENANCE_MARGIN_RATIO=0.33
HARD_DERISK_ON_CRISIS_OPEN_GROUP=false

# --- 8) Hedging ---------------------------------------------------------------
# 預設關閉 perp hedge；開啟後才需要 delta cap。
ENABLE_PERP_HEDGE=false
# SOFT_HEDGE_DELTA_CAP_PCT=0.10
# HARD_HEDGE_DELTA_CAP_PCT=0.05

# --- 9) 併發、節奏與執行 ------------------------------------------------------
# Per-book 上限以 MAX_GROUPS_PER_CURRENCY 為準（engine 未使用 MAX_GROUPS_PER_BOOK）。
MAX_CONCURRENT_GROUPS=6
MAX_GROUPS_PER_CURRENCY=3
ENTRY_COOLDOWN_MINUTES=20
ENABLE_IV_ENTRY_GATE=false
MIN_IV_RANK=0
MAX_IV_RANK=1
# Optional per-underlying overrides; unset keys fall back to MIN_IV_RANK / MAX_IV_RANK.
# BTC_MIN_IV_RANK=0.25
# ETH_MIN_IV_RANK=0.20
# BTC_MAX_IV_RANK=1
# ETH_MAX_IV_RANK=1
MIN_IV_MINUS_RV=0
IV_RANK_LOOKBACK_DAYS=365
RV_LOOKBACK_DAYS=30
ENABLE_WEIGHTED_CANDIDATE_SCORING=false
SCORE_WEIGHT_NET_APR=3
SCORE_WEIGHT_MARGIN_EFFICIENCY=2
SCORE_WEIGHT_SPREAD=1
SCORE_WEIGHT_DELTA_DISTANCE=1
SCORE_WEIGHT_OTM_DISTANCE=0.5
ENABLE_DYNAMIC_TP=false
TP_CAPTURE_PCT_DTE_LONG=0.40
TP_CAPTURE_PCT_DTE_SHORT=0.60
TP_DTE_LONG_THRESHOLD=14
TP_DTE_SHORT_THRESHOLD=7
REPRICE_MINUTES=3
RECOVERY_NORMAL_CYCLES=3
COOLDOWN_HOURS=12

# Deribit option fee 估算與下單等待時間。
OPTION_FEE_RATE=0.0003
OPTION_FEE_CAP_RATE=0.125
# Account trading-fee discount (0.10 = pay 90% of schedule for N months from registration).
# OPTION_FEE_DISCOUNT_RATE=0.10
# OPTION_FEE_DISCOUNT_MONTHS=6
# OPTION_FEE_DISCOUNT_ANCHOR=registration
# OPTION_FEE_DISCOUNT_REGISTRATION_MS=0
EXIT_BUFFER_RATIO=0.03
SHORT_ENTRY_WAIT_SECONDS=120
ORDER_POLL_SECONDS=10
POLL_SECONDS_NORMAL=15
POLL_SECONDS_STRESS=5

# --- 10) 狀態與本地工具 -------------------------------------------------------
ENABLE_NAKED_TOPUP=false
ENABLE_ADOPT_EXCHANGE_POSITIONS=true
ORDER_LABEL_PREFIX=naked_short
REQUEST_TIMEOUT_SECONDS=20
STATE_FILE=.state/naked_short.json

# `./bot frontend` 本地 dashboard 沒設私鑰時會跳過帳戶快照，但仍可讀本地
# state / report。快照間隔建議用 CLI 覆蓋：
#   ./bot frontend --snapshot-interval-sec 300

# --- 11) Telegram 告警（可選）------------------------------------------------
# 建議放在 config/shared/.env.defaults（全投資人共用），詳見 docs/telegram-alerts-zh-TW.md
# TELEGRAM_ALERTS_ENABLED=true
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# TELEGRAM_ALERT_COOLDOWN_SECONDS=300
