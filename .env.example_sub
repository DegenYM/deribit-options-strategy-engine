# =============================================================================
# 子帳戶／專用 API Key 的「帳戶層」環境檔範本
# =============================================================================
# 使用方式：
#   1. cp .env.example_sub .env.<OPTION_STRATEGY>_sub
#      例如：cp .env.example_sub .env.naked_short_sub
#   2. 填入該 Deribit 子帳戶（或獨立 key）的 DERIBIT_CLIENT_ID / DERIBIT_CLIENT_SECRET
#   3. 確認 OPTION_STRATEGY 與檔名中的策略一致；程式會再疊加同目錄的 .env.<strategy>
#      （策略的 delta、OTM、APR 等仍由該 profile 管理，本檔只管憑證與帳戶級設定）
#   4. 每個子帳戶使用不同的 ORDER_LABEL_PREFIX 與 STATE_FILE，避免訂單標籤與狀態檔衝突
#
# covered_call 注意：若主帳 .env 也在跑 covered_call，請避免與本檔共用同一 STATE_FILE
# （見 README「多子帳戶」一節）。

# --- 環境與憑證（必填，private 指令）------------------------------------------
DERIBIT_ENV=testnet
DERIBIT_CLIENT_ID=
DERIBIT_CLIENT_SECRET=

# 須與檔名中的策略一致，例如 .env.bull_put_spread_sub → bull_put_spread
OPTION_STRATEGY=naked_short

# --- 帳戶隔離（每個 sub 各一組）----------------------------------------------
ORDER_LABEL_PREFIX=naked_short
STATE_FILE=.state/naked_short.json

# --- 帳戶本地資金與掃描範圍（可依子帳資金調整）------------------------------
MANAGED_CURRENCIES=BTC,ETH
SCAN_UNDERLYINGS=BTC,ETH
MIN_BOOK_EQUITY_USDC=50
REFERENCE_CAPITAL_USDC=1000
TARGET_PORTFOLIO_APR=0.25
TOP_N=5

ENABLE_PERP_HEDGE=false
ENABLE_ADOPT_EXCHANGE_POSITIONS=true
REQUEST_TIMEOUT_SECONDS=20
