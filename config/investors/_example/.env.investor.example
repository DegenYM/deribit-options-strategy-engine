# Investor-level fee billing (optional). Loaded before sub-account env files.
# See docs/investor-fee-disclosure-zh-TW.md

# Optional: covered-call spot held off NAV_perf (deducted as BTC + ETH in reports). Default 0.
# COLLATERAL_SPOT_BTC=0
# COLLATERAL_SPOT_ETH=0

# Fee rates (defaults match disclosure: 10% performance, 1% p.a. management).
PERFORMANCE_FEE_RATE=0.10
MANAGEMENT_FEE_ANNUAL_RATE=0.01

# Optional starting high-water mark (NAV_perf). Omit to auto-bootstrap from transaction log on first snapshot.
# INITIAL_HWM_NAV_PERF=100000

# Transaction-log scan start (UTC). Default: 2026-01-01 when omitted.
# FEE_FLOW_START_DATE=2026-01-01
