# Deribit MAIN account API (not a subaccount). Required for internal-transfer between subaccounts.
# Create the key on the main account with Account=read + Wallet=read_write.
# Do NOT use for strategy trading; do NOT: ./bot run --env-file .../.env.main
ACCOUNT_ROLE=main
DERIBIT_ENV=testnet
DERIBIT_CLIENT_ID=
DERIBIT_CLIENT_SECRET=
ORDER_LABEL_PREFIX=demo_main
